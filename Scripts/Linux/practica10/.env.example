# ============================================================
# Variables de entorno - copia este archivo a .env y ajústalo
# ============================================================
# cp .env.example .env

# --- Base de datos ---
DB_USER=dualy
DB_PASSWORD=snowy180405
DB_NAME=prueba1

# --- FTP ---
FTP_USER=dualy
FTP_PASS=snowy180405
# Dirección IP/hostname que los clientes FTP usan para conectarse
# - Si pruebas LOCAL: 127.0.0.1
# - Si pruebas desde otra máquina: IP pública del host
PASV_ADDRESS=192.168.100.114

# --- Backup ---
# Cron estándar: minuto hora día-mes mes día-semana
#   "0 * * * *"       -> cada hora en punto (default)
#   "*/2 * * * *"     -> cada 2 minutos (útil para probar)
#   "0 2 * * *"       -> todos los días a las 2am
BACKUP_CRON=0 * * * *
