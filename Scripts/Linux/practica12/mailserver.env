OVERRIDE_HOSTNAME=mail.reprobados.com
DOMAINNAME=reprobados.com
POSTMASTER_ADDRESS=postmaster@reprobados.com

# SSL
SSL_TYPE=custom
SSL_CERT_PATH=/tmp/docker-mailserver/ssl/mail.reprobados.com-cert.pem
SSL_KEY_PATH=/tmp/docker-mailserver/ssl/mail.reprobados.com-key.pem

# Seguridad
ENABLE_FAIL2BAN=1
FAIL2BAN_BLOCKTYPE=drop

# Autenticación y firma
ENABLE_OPENDKIM=1

# Filtro de spam
ENABLE_RSPAMD=1
MOVE_SPAM_TO_JUNK=1

# ClamAV deshabilitado (consume ~700MB RAM; no necesario para la práctica)
ENABLE_CLAMAV=0

# Logging
LOG_LEVEL=info
POSTFIX_LOG_SUMMARY=yes

# Red
POSTFIX_INET_PROTOCOLS=ipv4
